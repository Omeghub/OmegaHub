local function getRemainingText()

    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return end

    local waveGui = gui:FindFirstChild("WaveTest")
    if not waveGui then return end

    local remaining = waveGui:FindFirstChild("Remaining")
    if not remaining then return end

    return remaining.Text
end

task.spawn(function()

    while task.wait(0.5) do

        if resetInProgress then continue end

        local text = getRemainingText()

        if text and string.find(text, "0") then

            if not zeroStartTime then
                zeroStartTime = tick()
            end

            if tick() - zeroStartTime >= RESET_DELAY then

                resetInProgress = true

                for i = 1, 2 do
                    resetCharacter()
                    task.wait(1.5)
                end

                zeroStartTime = nil
                resetInProgress = false
            end

        else
            zeroStartTime = nil
        end

    end

end)

