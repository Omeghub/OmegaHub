-- CHECK BOSS GUI
-- =========================================================
local function isBossActive()

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    local bossGui = playerGui:FindFirstChild("BossHealth")
    if not bossGui then return false end

    if bossGui.Enabled ~= true then return false end

    local mobHealth = bossGui:FindFirstChild("MobHealth")
    if not mobHealth then return false end

    local bar = mobHealth:FindFirstChild("Bar")
    if not bar then return false end

    return bar.Visible == false
end

local function getBoss()

    if not Workspace:FindFirstChild("Boss") then return end

    for _, obj in ipairs(Workspace.Boss:GetChildren()) do
        if obj:IsA("Model") then

            local hum = obj:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then
                return obj
            end
        end
    end
end

local function getNearestMob(hrp)

    local best
    local dist = MAX_DISTANCE

    for _,mob in ipairs(npcFolder:GetChildren()) do
        if mob:IsA("Model") then

            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then

                local pos
                local hrpMob = mob:FindFirstChild("HumanoidRootPart")

                if hrpMob then
                    pos = hrpMob.Position
                else
                    local success, pivot = pcall(function()
                        return mob:GetPivot()
                    end)
                    if success and pivot then
                        pos = pivot.Position
                    end
                end

                if pos then
                    local d = (pos - hrp.Position).Magnitude

                    if d < dist then
                        dist = d
                        best = mob
                    end
                end
            end
        end
    end

    return best
end

local function checkHeal(root)

    for _,obj in ipairs(visualsFolder:GetChildren()) do
        if obj:IsA("Part") and obj.Name == "Heal" then

            StopFly()
            task.wait(0.1)

            root.CFrame = obj.CFrame

            task.wait(0.5)
            return true
        end
    end

    return false
end

local function AutoFarm()

    local startTime = tick()

    while autoFarmDungeon do

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if not hrp then
            task.wait()
            continue
        end

        if checkHeal(hrp) then
            continue
        end

        local mob

        if game.PlaceId == BOSS_PLACE_ID and isBossActive() then
            mob = getBoss()
        else
            mob = getNearestMob(hrp)
        end

        if mob then

            local mobCFrame

            local hrpMob = mob:FindFirstChild("HumanoidRootPart")

            if hrpMob then
                mobCFrame = hrpMob.CFrame
            else
                local success, pivot = pcall(function()
                    return mob:GetPivot()
                end)
                if success and pivot then
                    mobCFrame = pivot
                end
            end

            if mobCFrame then

                local timeElapsed = tick() - startTime

                local oscillation =
                    math.sin(timeElapsed * oscillationSpeed) * oscillationAmplitude

                local targetPos =
                    mobCFrame.Position + Vector3.new(0, tpHeight, oscillation)

                StartFly(hrp)

                hrp.CFrame = CFrame.new(targetPos)

                if BG then
                    BG.CFrame = CFrame.lookAt(hrp.Position, mobCFrame.Position)
                end

                for _,v in ipairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end

        task.wait(0.08)
    end

    StopFly()
end

task.spawn(function()

    while true do
        if autoFarmDungeon then
            AutoFarm()
        end
        task.wait(1)
    end

end)
