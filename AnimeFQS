-- AUTO FARM DUNGEON + FLY AU-DESSUS
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local npcFolder = Workspace:WaitForChild("NPCs")
local visualsFolder = Workspace:WaitForChild("Visuals")

local tpHeight = 6
local tpSpeed = 200

local oscillationAmplitude = 0
local oscillationSpeed = 0

local MAX_DISTANCE = 500
local autoFarmDungeon = false

local FLYING = false
local BG, BV

Tabs.Main:AddSection("Auto Tp")

Tabs.Main:AddToggle("AutoFarmDungeonAFQ",{
    Title = "Auto Farm Dungeon",
    Default = false,
    Callback = function(v)
        autoFarmDungeon = v
    end
})

Tabs.Main:AddSlider("TPHeightAFQ",{
    Title = "TP Height",
    Min = 3,
    Max = 20,
    Default = tpHeight,
    Rounding = 1,
    Callback = function(v)
        tpHeight = v
    end
})

Tabs.Main:AddSlider("TPSpeedAFQ",{
    Title = "TP Speed",
    Min = 50,
    Max = 400,
    Default = tpSpeed,
    Rounding = 1,
    Callback = function(v)
        tpSpeed = v
    end
})

local function StartFly(hrp)
    if FLYING then return end
    FLYING = true

    BG = Instance.new("BodyGyro")
    BV = Instance.new("BodyVelocity")

    BG.P = 9e4
    BG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    BG.CFrame = hrp.CFrame
    BG.Parent = hrp

    BV.MaxForce = Vector3.new(9e9,9e9,9e9)
    BV.Velocity = Vector3.new(0,0,0)
    BV.Parent = hrp
end

local function StopFly()
    FLYING = false
    if BG then BG:Destroy() BG = nil end
    if BV then BV:Destroy() BV = nil end
end

local function getNearestMob(hrp)

    local best
    local dist = MAX_DISTANCE

    for _,mob in ipairs(npcFolder:GetChildren()) do

        if mob:IsA("Model") then

            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then

                local pos = mob:GetPivot().Position
                local d = (pos - hrp.Position).Magnitude

                if d < dist then
                    dist = d
                    best = mob
                end

            end
        end
    end

    return best
end

local function checkHeal(root)

    for _,obj in ipairs(visualsFolder:GetChildren()) do

        if obj:IsA("Part") and obj.Name == "Heal" then

            root.CFrame = obj.CFrame + Vector3.new(0,2,0)
            task.wait(1)
            return true
        end
    end

    return false
end

local function AutoFarm()

    local startTime = tick()

    while autoFarmDungeon do

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if not hrp then
            task.wait()
            continue
        end

        if checkHeal(hrp) then
            continue
        end

        local mob = getNearestMob(hrp)

        if mob and mob:FindFirstChild("HumanoidRootPart") then

            local mobRoot = mob.HumanoidRootPart
            local timeElapsed = tick() - startTime

            local oscillation =
                math.sin(timeElapsed * oscillationSpeed) * oscillationAmplitude

            local targetPos =
                mobRoot.Position + Vector3.new(0,tpHeight,oscillation)

            StartFly(hrp)

            local dir = (targetPos - hrp.Position)

            if dir.Magnitude > 1 then
                BV.Velocity = dir.Unit * tpSpeed
            end

            BG.CFrame = CFrame.lookAt(hrp.Position, mobRoot.Position)

            for _,v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end

        end

        task.wait()
    end

    StopFly()
end

task.spawn(function()

    while true do

        if autoFarmDungeon then
            AutoFarm()
        end

        task.wait(1)
    end

end)
