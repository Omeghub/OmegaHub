local visualsFolder = Workspace:WaitForChild("Visuals")

local BOSS_PLACE_ID = 113963744934619

local tpHeight = 6
local oscillationAmplitude = 2
local oscillationSpeed = 5

local MAX_DISTANCE = 5000
local autoFarmDungeon = false

local FLYING = false
local BG, BV

Tabs.Main:AddSection("Auto Tp")

Tabs.Main:AddToggle("AutoFarmDungeonAFQ",{
    Title = "Auto Farm Dungeon",
    Default = false,
    Callback = function(v)
        autoFarmDungeon = v
