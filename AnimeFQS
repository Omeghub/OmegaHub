local RarityEmoji = {
    Common = "⚪",
    Rare = "🔵",
    Epic = "🟣",
    Legendary = "🟡",
    Mythic = "🔴",
    Exclusive = "🟥"
}

local function sendWebhook(rewards)

    if WebhookUrl == "" then return end

    local text = ""

    for _, r in ipairs(rewards) do

        local rarity = r.rarity
        if rarity == "Unknown" or rarity == "UIGradient" then
            rarity = "Common"
        end

        local emoji = RarityEmoji[rarity] or "⚪"

        text = text ..
            emoji .. " **" .. r.name .. "**\n" ..
            "Quantity: " .. r.quantity .. "\n" ..
            "Rarity: " .. rarity .. "\n\n"
    end

    if text == "" then
        text = "No rewards detected"
    end

    HttpRequest({
        Url = WebhookUrl,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json"
        },
        Body = HttpService:JSONEncode({
            username = "Anime Finals Quest",
            embeds = {
                {
                    title = "🎁 Dungeon Rewards",
                    description = text,
                    color = 0, -- neutre (pas de couleur embed)
                    footer = {
                        text = os.date("%d/%m/%Y %H:%M")
                    }
                }
            }
        })
    })
end

local function getRewards()

    local rewards = {}

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return rewards end

    local endScreen = playerGui:FindFirstChild("EndScreen")
    if not endScreen or not endScreen.Enabled then return rewards end

    local screen = endScreen:FindFirstChild("Screen")
    local frame = screen and screen:FindFirstChild("Frame")
    local frame2 = frame and frame:FindFirstChild("Frame2")
    local itemsFrame = frame2 and frame2:FindFirstChild("Frame")

    if not itemsFrame or not itemsFrame.Visible then return rewards end

    for _, item in ipairs(itemsFrame:GetChildren()) do
        if item:IsA("ImageLabel")
        and item.Name ~= "Template"
        and item.Name ~= "Reward1" then

            local nameLabel = item:FindFirstChild("ItemName")
            local qtyLabel = item:FindFirstChild("Quantity")

            local itemName = nameLabel and nameLabel.Text or "Unknown"
            local quantity = qtyLabel and qtyLabel.Text or "1"

            local rarity = "Common"

            for _, grad in ipairs(item:GetChildren()) do
                if grad:IsA("UIGradient") and grad.Enabled then
                    rarity = grad.Name
                    break
                end
            end

            if rarity == "UIGradient" then
                rarity = "Common"
            end

            table.insert(rewards, {
                name = itemName,
                quantity = quantity,
                rarity = rarity
            })
        end
    end

    return rewards
end

local alreadySent = false

task.spawn(function()

    while task.wait(0.5) do

        if WebhookUrl == "" then continue end

        local playerGui = player:FindFirstChild("PlayerGui")
        if not playerGui then continue end

        local endScreen = playerGui:FindFirstChild("EndScreen")
        if not endScreen then continue end

        local screen = endScreen:FindFirstChild("Screen")
        local frame = screen and screen:FindFirstChild("Frame")
        local frame2 = frame and frame:FindFirstChild("Frame2")
        local itemsFrame = frame2 and frame2:FindFirstChild("Frame")

        if endScreen.Enabled
        and frame and frame.Visible
        and frame2 and frame2.Visible
        and itemsFrame and itemsFrame.Visible then

            if not alreadySent then
                alreadySent = true

                task.wait(1)

                local rewards = getRewards()
                sendWebhook(rewards)
            end

        else
            alreadySent = false
        end

    end

end)
