local function StartFly(hrp)
    if FLYING then return end
    FLYING = true

    BG = Instance.new("BodyGyro")
    BV = Instance.new("BodyVelocity")

    BG.P = 9e4
    BG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    BG.Parent = hrp

    BV.MaxForce = Vector3.new(9e9,9e9,9e9)
    BV.Velocity = Vector3.new(0,0.1,0)
    BV.Parent = hrp
end

local function StopFly()
    FLYING = false
    if BG then BG:Destroy() BG = nil end
    if BV then BV:Destroy() BV = nil end
end

local function resetCharacter()
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Health = 0
        end
    end
end

local function isFullHealth()

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    local screen = playerGui:FindFirstChild("ScreenGuiIngame")
    if not screen then return false end

    local bar = screen:FindFirstChild("Healtbar")
    if not bar then return false end

    local textLabel = bar:FindFirstChild("HealthBarText")
    if not textLabel then return false end

    local text = textLabel.Text -- "490/490"

    local current, max = string.match(text, "(%d+)%s*/%s*(%d+)")

    current = tonumber(current)
    max = tonumber(max)

    if current and max then
        return current >= max
    end

    return false
end

local function checkHeal(root)

    if isFullHealth() then
        return false
    end

    for _,obj in ipairs(visualsFolder:GetChildren()) do
        if obj:IsA("Part") and obj.Name == "Heal" then

            StopFly()
            task.wait(0.1)

            root.CFrame = obj.CFrame

            task.wait(0.5)
            return true
        end
    end

    return false
end

local function isBossActive()

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    local bossGui = playerGui:FindFirstChild("BossHealth")
    if not bossGui then return false end

    if bossGui.Enabled ~= true then return false end

    local mobHealth = bossGui:FindFirstChild("MobHealth")
    if not mobHealth then return false end

    local bar = mobHealth:FindFirstChild("Bar")
    if not bar then return false end

    return bar.Visible == false
end

local function getBoss()

    if not Workspace:FindFirstChild("Boss") then return end

    for _, obj in ipairs(Workspace.Boss:GetChildren()) do
        if obj:IsA("Model") then

            local hum = obj:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then
                return obj
            end
        end
    end
end

local function getNearestMob(hrp)

    local best
    local dist = MAX_DISTANCE

    for _,mob in ipairs(npcFolder:GetChildren()) do
        if mob:IsA("Model") then

            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then

                local pos
                local hrpMob = mob:FindFirstChild("HumanoidRootPart")

                if hrpMob then
                    pos = hrpMob.Position
                else
                    local success, pivot = pcall(function()
                        return mob:GetPivot()
                    end)
                    if success and pivot then
                        pos = pivot.Position
                    end
                end

                if pos then
                    local d = (pos - hrp.Position).Magnitude

                    if d < dist then
                        dist = d
                        best = mob
                    end
                end
            end
        end
    end

    return best
end

local function AutoFarm()

    local startTime = tick()

    while autoFarmDungeon do

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if not hrp then
            task.wait()
            continue
        end

        if checkHeal(hrp) then
            continue
        end

    local mob

    if SPECIAL_PLACE_IDS[game.PlaceId] then

        local bossFolder = Workspace:FindFirstChild("Boss")

        if bossFolder then
            for _, boss in ipairs(bossFolder:GetChildren()) do
                if boss:IsA("Model") and SPECIAL_BOSS_NAMES[boss.Name] then

                    local hum = boss:FindFirstChildOfClass("Humanoid")

                    if hum and hum.Health > 0 then
                        mob = boss
                        break
                    end
                end
            end
        end

        if not mob then
            mob = getNearestMob(hrp)
        end

        elseif game.PlaceId == BOSS_PLACE_ID and isBossActive() then
            mob = getBoss()
        else
            mob = getNearestMob(hrp)
        end

        if mob then

            local mobCFrame

            local hrpMob = mob:FindFirstChild("HumanoidRootPart")

            if hrpMob then
                mobCFrame = hrpMob.CFrame
            else
                local success, pivot = pcall(function()
                    return mob:GetPivot()
                end)
                if success and pivot then
                    mobCFrame = pivot
                end
            end

            if mobCFrame then

                local currentPos = hrp.Position

                if lastPosition then
                    local moveDist = (currentPos - lastPosition).Magnitude
                    local mobDist = (currentPos - mobCFrame.Position).Magnitude

                    if moveDist < 1 and mobDist > SAFE_DISTANCE_FROM_MOB then
                        if tick() - lastMoveTime > STUCK_TIME then
                            resetCharacter()
                            lastMoveTime = tick()
                        end
                    else
                        lastMoveTime = tick()
                    end
                end

                lastPosition = currentPos

                local timeElapsed = tick() - startTime

                local oscillation =
                    math.sin(timeElapsed * oscillationSpeed) * oscillationAmplitude

                local targetPos

                    if SPECIAL_PLACE_IDS[game.PlaceId] and SPECIAL_BOSS_NAMES[mob.Name] then
                        local dir = (hrp.Position - mobCFrame.Position).Unit
                        targetPos = mobCFrame.Position + dir * SPECIAL_DISTANCE + Vector3.new(0, tpHeight, 0)
                    else
                        targetPos = mobCFrame.Position + Vector3.new(0, tpHeight, oscillation)
                    end
                StartFly(hrp)

                hrp.CFrame = CFrame.new(targetPos)

                if BG then
                    BG.CFrame = CFrame.lookAt(hrp.Position, mobCFrame.Position)
                end

                for _,v in ipairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end

        task.wait(0.08)
    end

    StopFly()
end

task.spawn(function()

    while true do
        if autoFarmDungeon then
            AutoFarm()
        end
        task.wait(1)
    end

end)
