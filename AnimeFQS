local player = Players.LocalPlayer
local npcFolder = Workspace:WaitForChild("NPCs")
local visualsFolder = Workspace:WaitForChild("Visuals")

local BOSS_PLACE_ID = 113963744934619
local SPECIAL_PLACE_IDS = {
    [73912821025828] = true,
    [81100481912247] = true,
    [95240177479580] = true
}
local SPECIAL_BOSS_NAMES = {
    ["Restless Gambler"] = true,
    ["Boss"] = true
    ["DIO"] = true
}
local SPECIAL_DISTANCE = 15

local tpHeight = 6
local oscillationAmplitude = 2
local oscillationSpeed = 5

local MAX_DISTANCE = 10000
local autoFarmDungeon = false

local FLYING = false
local BG, BV

local lastPosition = nil
local lastMoveTime = tick()
local STUCK_TIME = 60
local SAFE_DISTANCE_FROM_MOB = 15

Tabs.Main:AddSection("Auto Tp")

Tabs.Main:AddToggle("AutoFarmDungeonAFQ",{
    Title = "Auto Farm Dungeon",
    Default = false,
