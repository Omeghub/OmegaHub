local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local npcFolder = Workspace:WaitForChild("NPCs")

local SelectedMob = nil
local MobList = {}

local tpHeight = 6
local autoTP = false

local function RefreshMobs()

    MobList = {}
    local temp = {}

    for _,mob in pairs(npcFolder:GetChildren()) do
        
        local name = mob.Name:gsub("%d+$","")

        if not table.find(temp,name) then
            table.insert(temp,name)
        end

    end

    MobList = temp

end

RefreshMobs()

local Section = Tabs.Main:AddSection("Auto Tp")

local MobDropdown = Tabs.Main:AddDropdown("MobSelectSailor", {
    Title = "Select Mob",
    Values = MobList,
    Multi = false,
    Default = 1,
    Callback = function(Value)
        SelectedMob = Value
    end
})

Tabs.Main:AddButton({
    Title = "Refresh Mobs",
    Callback = function()

        RefreshMobs()
        MobDropdown:SetValues(MobList)

    end
})

Tabs.Main:AddToggle("AutoTPMobSailor",{
    Title = "Auto TP Mob",
    Default = false,
    Callback = function(v)
        autoTP = v
    end
})

Tabs.Main:AddSlider("TPHeightSailor",{
    Title = "TP Height",
    Min = 3,
    Max = 20,
    Default = tpHeight,
    Rounding = 1,
    Callback = function(v)
        tpHeight = v
    end
})

local function getTargetMob()

    for _,mob in ipairs(npcFolder:GetChildren()) do

        local name = mob.Name:gsub("%d+$","")

        if name == SelectedMob then

            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then
                return mob
            end

        end

    end

end

local function AutoFarm()

    while autoTP do

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if not hrp then
            task.wait()
            continue
        end

        local mob = getTargetMob()

        if mob then

            local mobPosition

            local mobHRP = mob:FindFirstChild("HumanoidRootPart")

            if mobHRP then
                mobPosition = mobHRP.Position
            else
                mobPosition = mob:GetPivot().Position
            end

            local targetPos = mobPosition + Vector3.new(0,tpHeight,0)

            hrp.CFrame =
                CFrame.lookAt(targetPos, mobPosition)
                * CFrame.Angles(math.rad(90),0,0)

            for _,v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end

        end

        task.wait()

    end

end

task.spawn(function()

    while true do

        if autoTP then
            AutoFarm()
        end

        task.wait(0.5)

    end

end)
