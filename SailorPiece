local function getPlayerLevel()

    local levelLabel = player.PlayerGui
        .BasicStatsCurrencyAndButtonsUI
        .MainFrame
        .LevelInfo
        .LevelFrame
        .AutoSizeHolder
        .Level

    return tonumber(levelLabel.Text:match("%d+"))

end

local function isQuestActive()

    local questUI = player.PlayerGui:WaitForChild("QuestUI"):WaitForChild("Quest")

    return questUI.Visible

end

local function findQuestForLevel()

    local playerLevel = getPlayerLevel()

    for _,npc in pairs(workspace.ServiceNPCs:GetChildren()) do

        local hrp = npc:FindFirstChild("HumanoidRootPart")

        if hrp then

            local prompt = hrp:FindFirstChild("QuestPrompt")

            if prompt then

                local questText = prompt.ObjectText
                local min,max = questText:match("Lvl%s*(%d+)%-(%d+)")

                if min and max then

                    min = tonumber(min)
                    max = tonumber(max)

                    if playerLevel >= min and playerLevel <= max then
                        return npc
                    end

                end

            end

        end

    end

end

local function slideToNextQuestNPC()

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if not hrp then return end

    local closestNPC
    local distance = math.huge

    for _,npc in pairs(workspace.ServiceNPCs:GetChildren()) do

        local pos = npc:GetPivot().Position
        local dist = (pos - hrp.Position).Magnitude

        if dist < distance then
            distance = dist
            closestNPC = npc
        end

    end

    if not closestNPC then return end

    local currentIndex = tonumber(closestNPC.Name:match("%d+"))
    local nextNPC = workspace.ServiceNPCs:FindFirstChild("QuestNPC"..(currentIndex + 1))

    if not nextNPC then return end

    local targetPos = nextNPC:GetPivot().Position + Vector3.new(0,3,0)

    local speed = 120

    while (hrp.Position - targetPos).Magnitude > 5 do

        local dir = (targetPos - hrp.Position).Unit
        hrp.Velocity = dir * speed

        task.wait()

    end

    hrp.Velocity = Vector3.zero

end

local function getQuestMob()

    local questTitle = player.PlayerGui
        .QuestUI
        .Quest
        .Quest
        .Holder
        .Content
        .QuestInfo
        .QuestTitle
        .QuestTitle

    local text = questTitle.Text
    local mob = text:match("^(%w+)")

    if text:find("Boss") then
        mob = mob.."Boss"
    end

    return mob

end

local function findMob(mobName)

    for _,mob in pairs(workspace.NPCs:GetChildren()) do

        local name = mob.Name:gsub("%d+$","")

        if name:find(mobName) then

            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hum and hum.Health > 0 then
                return mob
            end

        end

    end

end

task.spawn(function()

    while task.wait(1) do

        if autoQuestFarm and not isQuestActive() then

            local questNPC = findQuestForLevel()

            if questNPC then

                questRemote:FireServer(questNPC.Name)

            else

                slideToNextQuestNPC()

            end

        end

    end

end)

task.spawn(function()

    while task.wait(0.15) do

        if autoQuestFarm and isQuestActive() then

            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if not hrp then continue end

            local mobName = getQuestMob()

            if mobName then

                local mob = findMob(mobName)

                if mob then

                    local mobPos
                    local mobHRP = mob:FindFirstChild("HumanoidRootPart")

                    if mobHRP then
                        mobPos = mobHRP.Position
                    else
                        mobPos = mob:GetPivot().Position
                    end

                    local targetPos = mobPos + Vector3.new(0,tpHeight,0)

                    hrp.CFrame =
                        CFrame.lookAt(targetPos, mobPos) *
                        CFrame.Angles(math.rad(90),0,0)

                end

            end

        end

    end

end)
