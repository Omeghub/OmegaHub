-- AUTO TP MOBS (FIX VOID + OPTIMIZED)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local liveFolder = workspace:WaitForChild("MainWorkspaceComponents"):WaitForChild("Living")
local fxFolder = workspace:WaitForChild("MainWorkspaceComponents"):WaitForChild("FX")

local autoTP = false
local distance = 6
local currentMob = nil
local FLYING = false
local BG, BV

local function StartFly(hrp)
    if FLYING then return end
    FLYING = true

    BG = Instance.new("BodyGyro")
    BV = Instance.new("BodyVelocity")

    BG.P = 9e4
    BG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    BG.Parent = hrp

    BV.MaxForce = Vector3.new(9e9,9e9,9e9)
    BV.Velocity = Vector3.new(0,0.1,0)
    BV.Parent = hrp
end

local function StopFly()
    FLYING = false
    if BG then BG:Destroy() BG = nil end
    if BV then BV:Destroy() BV = nil end
end

-- UI
Tabs.Main:AddToggle("AutoTPMob", {
    Title = "Auto TP Mobs",
    Default = false,
    Callback = function(value)
        autoTP = value
        if not value then StopFly() end
    end
})

Tabs.Main:AddSlider("MobDistance", {
    Title = "Height",
    Default = 6,
    Min = 3,
    Max = 20,
    Rounding = 1,
    Callback = function(value)
        distance = value
    end
})

local function isPlayer(mob)
    return Players:GetPlayerFromCharacter(mob) ~= nil
end

local function getAliveMob()
    local char = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")

    for _, mob in pairs(liveFolder:GetChildren()) do
        if not isPlayer(mob) then
            local hum = mob:FindFirstChildOfClass("Humanoid")
            local hrp = mob:FindFirstChild("HumanoidRootPart")

            if hum and hrp and hum.Health > 0 then
                
                if hrp.Position.Y < -50 then continue end

                if myHRP and (myHRP.Position - hrp.Position).Magnitude > 1000 then continue end

                return mob
            end
        end
    end
end

local function getMarker()
    for _, obj in pairs(fxFolder:GetChildren()) do
        if obj:IsA("Part") and obj.Name == "Marker" then
            return obj
        end
    end
end

task.spawn(function()
    while task.wait(0.05) do

        if autoTP then

            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            StartFly(hrp)

            local marker = getMarker()

            if marker then
                local pos = marker.Position + Vector3.new(0, distance, 0)

                hrp.CFrame = CFrame.new(pos)

                if BG then
                    BG.CFrame = CFrame.lookAt(hrp.Position, marker.Position)
                end

                continue
            end

            if currentMob then
                local mobHRP = currentMob:FindFirstChild("HumanoidRootPart")
                if not currentMob.Parent
                or isPlayer(currentMob)
                or not currentMob:FindFirstChildOfClass("Humanoid")
                or currentMob:FindFirstChildOfClass("Humanoid").Health <= 0
                or (mobHRP and mobHRP.Position.Y < -50) then
                    currentMob = nil
                end
            end

            if not currentMob then
                currentMob = getAliveMob()
            end

            if currentMob then
                local mobHRP = currentMob:FindFirstChild("HumanoidRootPart")
                if not mobHRP then continue end

                local targetPos = mobHRP.Position + Vector3.new(0, -distance, 0)

                hrp.CFrame = CFrame.new(targetPos)

                if BG then
                    BG.CFrame = CFrame.lookAt(hrp.Position, mobHRP.Position)
                end

                for _,v in ipairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end
    end
end)
