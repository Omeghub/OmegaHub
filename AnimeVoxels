-- AUTO ATTACK + DMG VOID

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

local autoAttack = false
local dmgVoid = false

local trackedMobs = {}
local connections = {}

local function getMobTorso(mob)
    return mob:FindFirstChild("HumanoidRootPart")
        or mob:FindFirstChild("Torso")
        or mob:FindFirstChild("UpperTorso")
end

local function voidMob(mob)
    local torso = getMobTorso(mob)
    if torso then
        torso.CFrame = CFrame.new(0, -9999, 0)
    end
end

local function trackMob(mob)
    if trackedMobs[mob] then return end

    local humanoid = mob:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    trackedMobs[mob] = true

    local lastHealth = humanoid.Health

    connections[mob] = humanoid.HealthChanged:Connect(function(newHealth)
        if not dmgVoid then return end

        if newHealth < lastHealth then
            voidMob(mob)
        end

        lastHealth = newHealth
    end)
end

local function startTracking()
    local livingFolder = workspace:WaitForChild("MainWorkspaceComponents"):WaitForChild("Living")

    for _, mob in pairs(livingFolder:GetChildren()) do
        if mob.Name ~= player.Name then
            trackMob(mob)
        end
    end

    connections["spawn"] = livingFolder.ChildAdded:Connect(function(mob)
        task.wait(0.1)
        if mob.Name ~= player.Name then
            trackMob(mob)
        end
    end)
end

local function stopTracking()
    for _, conn in pairs(connections) do
        if typeof(conn) == "RBXScriptConnection" then
            conn:Disconnect()
        end
    end

    trackedMobs = {}
    connections = {}
end

task.spawn(function()
    while true do
        if autoAttack then
            local args = {
                Enum.KeyCode.Unknown,
                Enum.UserInputType.MouseButton1,
                [4] = { holdingControl = false }
            }

            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Input"):FireServer(unpack(args))
        end
        
        task.wait(0.1)
    end
end)


Tabs.Main:AddToggle("AutoAttack",{
    Title = "Auto Attack",
