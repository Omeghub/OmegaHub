    end
})

Tabs.Main:AddToggle("DmgVoid",{
    Title = "Damage Void (Kill Fast)",
    Default = false,
    Callback = function(state)
        dmgVoid = state

        if state then
            startTracking()
        else
            stopTracking()
        end
    end
})
