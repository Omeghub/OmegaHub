-- AUTO NEXT STAGE + AUTO REPLAY (PRIORITY SYSTEM)

local autoRound = false

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

local voteRemote = ReplicatedStorage:WaitForChild("Systems"):WaitForChild("Voting"):WaitForChild("Vote")

task.spawn(function()
    local fired = false

    while task.wait(0.3) do
        if autoRound then

            local gui = player:FindFirstChild("PlayerGui")
            local roundEnd = gui and gui:FindFirstChild("RoundEnd")

            local frame = roundEnd and roundEnd:FindFirstChild("Frame")
            local contents = frame and frame:FindFirstChild("Contents")
            local buttonsHolder = contents and contents:FindFirstChild("ButtonsHolder")
            local buttons = buttonsHolder and buttonsHolder:FindFirstChild("Buttons")

            local nextBtn = buttons and buttons:FindFirstChild("NextStageButton")
            local retryBtn = buttons and buttons:FindFirstChild("RestartButton")

            local nextVisible = nextBtn and nextBtn.Visible
            local retryVisible = retryBtn and retryBtn.Visible

            if roundEnd and roundEnd.Enabled and not fired then

                if nextVisible then
                    fired = true
                    task.wait(1)

                    voteRemote:FireServer("Next")

                elseif retryVisible then
                    fired = true
                    task.wait(1)

                    voteRemote:FireServer("Retry")
                end
            end

            if not roundEnd or not roundEnd.Enabled or (not nextVisible and not retryVisible) then
                fired = false
            end
        end
    end
end)

Tabs.Main:AddSection("Auto Replay / Next")

Tabs.Main:AddToggle("AutoNextReplay", {
    Title = "Auto Next / Replay",
    Description = "Next priorité sinon Replay",
    Default = false,
    Callback = function(state)
        autoRound = state
    end
})
