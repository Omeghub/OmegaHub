    Default = false,
    Callback = function(v)
        autoBlock = v
    end
})

RunService.Heartbeat:Connect(function()

    if not autoBlock then return end

    local character = player.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, enemy in pairs(enemiesFolder:GetChildren()) do

        local enemyRoot = enemy:FindFirstChild("HumanoidRootPart")
        local cooldown = enemy:FindFirstChild("combatCooldown")

        if enemyRoot and cooldown then

            local dist = (enemyRoot.Position - root.Position).Magnitude

            if dist <= blockDistance then

                if cooldown.Value and not blocking then

                    blocking = true

                    attackRemote:FireServer({
                        buffer = buffer.fromstring("\r\000\000\000General/Block\001\000\000\000\000"),
                        blobs = {}
                    })

                end

                if not cooldown.Value and blocking then

                    blocking = false

                    attackRemote:FireServer({
                        buffer = buffer.fromstring("\r\000\000\000General/Block\000\000\000\000\000"),
                        blobs = {}
                    })

                end

            end

        end

    end

end)
