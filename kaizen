-- AUTO TP CHEST FAST

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local effects = workspace:WaitForChild("Effects")

local autoChest = false
local lastTP = 0
local chestIndex = 1

local Section = Tabs.Misc:AddSection("Auto Tp Loots")

Tabs.Misc:AddToggle("AutoChest", {
    Title = "Auto TP Chest",
    Default = false,
    Callback = function(value)
        autoChest = value
    end
})

RunService.Heartbeat:Connect(function()

    if not autoChest then return end
    if tick() - lastTP < 1 then return end

    local character = player.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local chests = {}

    for _, obj in ipairs(effects:GetDescendants()) do
        if obj:IsA("Model") and string.find(obj.Name, "Chest") then
            table.insert(chests, obj)
        end
    end

    if #chests == 0 then return end

    if chestIndex > #chests then
        chestIndex = 1
    end

    local chest = chests[chestIndex]
    local part = chest:FindFirstChildWhichIsA("BasePart")

    if part then
        character:PivotTo(part.CFrame)
        chestIndex += 1
        lastTP = tick()
    end

end)
