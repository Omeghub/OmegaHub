local function LoadModule(url)
    local module
    repeat
        local success, result = pcall(function()
            return loadstring(game:HttpGet(url))()
        end)
        if success then
            module = result
        else
            warn("Module non chargé, retry dans 1s : "..url)
            wait(1)
        end
    until module
    return module
end

