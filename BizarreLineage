-- AUTO QUEST (READ ALL SINGLEOBJECTIVE)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

local autoQuest = false

local npcFolder = workspace:WaitForChild("Npcs")
local npcCache = ReplicatedStorage:WaitForChild("assets"):WaitForChild("npc_cache")
local liveFolder = workspace:WaitForChild("Live")

local dialogueRemote = ReplicatedStorage:WaitForChild("requests"):WaitForChild("character"):WaitForChild("dialogue")

local Section = Tabs.Players:AddSection("Auto Quest")

Tabs.Players:AddToggle("AutoQuest",{
    Title = "Auto Quest",
    Default = false,
    Callback = function(v)
        autoQuest = v
    end
})

local function getObjectives()

    local holder = player.PlayerGui.menu.task_holder.holder.newobjective.ScrollingFrame.holder

    local talkNPC
    local defeatMob

    for _,objective in pairs(holder:GetChildren()) do

        if objective.Name == "singleobjective" then

            local label = objective:FindFirstChild("TextLabel")

            if label then

                local text = label.Text

                if string.find(text,"Talk to:") then

                    talkNPC = text:gsub("Talk to: ","")


                end

                if string.find(text,"Defeat") then

                    local mobName = text
                    mobName = mobName:gsub("Defeat ","")
                    mobName = mobName:gsub(" 「%d+/%d+」","")

                    defeatMob = mobName

                end

            end

        end

    end

    return talkNPC, defeatMob

end

local function tpToNPC(npcName)

    local character = player.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local npc = npcFolder:FindFirstChild(npcName)

    if npc then

        root.CFrame = npc:GetPivot()

        task.wait(0.5)

        dialogueRemote:FireServer(npc,1)

        return
    end

    local cache = npcCache:FindFirstChild(npcName)

    if cache then

        root.CFrame = cache:GetPivot()

    end

end

local function tpToMob(mobName)

    local character = player.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _,mob in pairs(liveFolder:GetChildren()) do

        local display = mob:GetAttribute("DisplayName")

        if display then

            if string.find(display:lower(),mobName:lower()) then

                root.CFrame = mob:GetPivot() * CFrame.new(0,0,6)

                return

            end

        end

    end

end

task.spawn(function()

    while task.wait(1) do

        if not autoQuest then continue end

        local npcName, mobName = getObjectives()

        if npcName then
            tpToNPC(npcName)
        end

        if mobName then
            tpToMob(mobName)
        end

    end

end)
