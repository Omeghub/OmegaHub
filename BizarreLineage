local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local liveFolder = workspace:WaitForChild("Live")

local spawnRemote = ReplicatedStorage:WaitForChild("requests"):WaitForChild("character"):WaitForChild("spawn")

local retryRemote = ReplicatedStorage:WaitForChild("requests"):WaitForChild("character"):WaitForChild("retryraid")

local autoRaid = false

local Section = Tabs.Raid:AddSection("Raid")

Tabs.Raid:AddToggle("AutoRaid",{
    Title = "Auto Raid",
    Default = false,
    Callback = function(v)
        autoRaid = v
    end
})

task.spawn(function()

    while task.wait(1) do

        if not autoRaid then continue end

        local mainMenu = playerGui:FindFirstChild("Main Menu")
        if not mainMenu then continue end

        local buttons = mainMenu:FindFirstChild("Buttons")
        if not buttons then continue end

        local quickPlay = buttons:FindFirstChild("Quick Play")
        if not quickPlay then continue end

        if mainMenu.Enabled and quickPlay.Visible then

            task.wait(5)

            if autoRaid then
                spawnRemote:FireServer()
                mainMenu.Enabled = false
            end

        end

    end

end)

task.spawn(function()

    while task.wait(0.15) do

        if not autoRaid then continue end

        local char = player.Character
        if not char then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        for _,mob in pairs(liveFolder:GetChildren()) do

            if mob.Name ~= "Server"
            and mob.Name ~= player.Name
            and not game.Players:FindFirstChild(mob.Name) then

                local humanoid = mob:FindFirstChildOfClass("Humanoid")

                if humanoid then

                    local pivot = mob:GetPivot()

                    root.CFrame = pivot * CFrame.new(0,0,5)

                    break
                end
            end
        end
    end
end)

local function tryRetry(raidcomplete, raid)

    if autoRaid and raidcomplete.Enabled and raid.Visible then

        retryRemote:FireServer()

    end

end

local function listenRaid(raidcomplete)

    local raid = raidcomplete:WaitForChild("raid")

    tryRetry(raidcomplete, raid)

    raid:GetPropertyChangedSignal("Visible"):Connect(function()
        tryRetry(raidcomplete, raid)
    end)

    raidcomplete:GetPropertyChangedSignal("Enabled"):Connect(function()
        tryRetry(raidcomplete, raid)
    end)

end

local existing = playerGui:FindFirstChild("raidcomplete")

if existing then
    listenRaid(existing)
end

playerGui.ChildAdded:Connect(function(child)

    if child.Name == "raidcomplete" then

        listenRaid(child)

    end

end)
